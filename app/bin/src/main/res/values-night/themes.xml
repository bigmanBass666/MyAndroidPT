<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyAndroidPT" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary (dark) -->
        <item name="colorPrimary">@color/green_200</item>
        <item name="colorOnPrimary">@color/green_900</item>
        <item name="colorPrimaryContainer">@color/green_700</item>
        <item name="colorOnPrimaryContainer">@color/green_200</item>

        <!-- Secondary (dark) -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/teal_900</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>
        <item name="colorOnSecondaryContainer">@color/teal_50</item>

        <!-- Tertiary (dark) -->
        <item name="colorTertiary">@color/amber_100</item>
        <item name="colorOnTertiary">@color/amber_900</item>
        <item name="colorTertiaryContainer">@color/amber_700</item>
        <item name="colorOnTertiaryContainer">@color/amber_100</item>

        <!-- Error (dark) -->
        <item name="colorError">@color/red_100</item>
        <item name="colorErrorContainer">@color/red_600</item>
        <item name="colorOnError">@color/red_900</item>
        <item name="colorOnErrorContainer">@color/red_100</item>

        <!-- Surface (dark) -->
        <item name="colorSurface">#FF1C1B1F</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">#FF49454F</item>
        <item name="colorOnSurfaceVariant">#FFCAC4D0</item>
        <item name="colorOutline">#FF938F99</item>
        <item name="colorOutlineVariant">#FF49454F</item>

        <!-- Status bar (dark) -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
