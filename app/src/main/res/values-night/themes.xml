<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyAndroidPT" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary (same as light — M3 DayNight handles automatically) -->
        <item name="colorPrimary">@color/green_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/green_700</item>
        <item name="colorOnPrimaryContainer">@color/green_200</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/teal_900</item>
        <item name="colorOnSecondaryContainer">@color/teal_50</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/amber_500</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorTertiaryContainer">@color/amber_700</item>
        <item name="colorOnTertiaryContainer">@color/amber_100</item>

        <!-- Error -->
        <item name="colorError">@color/red_600</item>
        <item name="colorErrorContainer">@color/red_900</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnErrorContainer">@color/red_100</item>

        <!-- Surface — dark overrides -->
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>
        <item name="colorOutline">@color/outline_dark</item>
        <item name="colorOutlineVariant">@color/surface_variant_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Shape tokens (same as light) -->
        <item name="shapeAppearanceCornerExtraSmall">@style/ShapeExtraSmall</item>
        <item name="shapeAppearanceCornerSmall">@style/ShapeSmall</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeMedium</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeLarge</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeExtraLarge</item>

        <!-- Typography tokens (same as light) -->
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.MyAndroidPT.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.MyAndroidPT.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MyAndroidPT.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MyAndroidPT.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MyAndroidPT.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.MyAndroidPT.LabelLarge</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MyAndroidPT.LabelSmall</item>
    </style>
</resources>
